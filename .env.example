# Server-side lead delivery
RESEND_API_KEY=re_example_only
SMTP_FROM=STRUKTIVA <anfragen@example.invalid>
LEAD_RECEIVER_EMAIL=anfragen@example.invalid
LEAD_WEBHOOK_URL=

# Add only the verified Google Ads conversion target in the form AW-123456789/label.
VITE_GOOGLE_ADS_DIGITAL_CHECK_SEND_TO=

# Confirmed gross-price note. The application uses this exact value as its safe default even when the variable is empty.
VITE_DIGITAL_CHECK_TAX_NOTE=inkl. 19 % MwSt.
