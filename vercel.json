{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/demos",
      "destination": "/praxisbeispiele",
      "permanent": true
    },
    {
      "source": "/referenzen",
      "destination": "/praxisbeispiele",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/digital-check/danke",
      "destination": "/digital-check/danke/index.html"
    },
    {
      "source": "/digital-check",
      "destination": "/digital-check/index.html"
    },
    {
      "source": "/demos/handwerker",
      "destination": "/demos/handwerker/index.html"
    },
    {
      "source": "/demos/kosmetik",
      "destination": "/demos/kosmetik/index.html"
    },
    {
      "source": "/demos/lokaler-dienstleister",
      "destination": "/demos/lokaler-dienstleister/index.html"
    },
    {
      "source": "/((?!api/)(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
