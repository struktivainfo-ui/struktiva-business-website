{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/demos/handwerker",
      "destination": "/demos/handwerker/index.html"
    },
    {
      "source": "/demo-handwerker",
      "destination": "/demos/handwerker/index.html"
    },
    {
      "source": "/demos/kosmetik",
      "destination": "/demos/kosmetik/index.html"
    },
    {
      "source": "/kosmetik-demo",
      "destination": "/demos/kosmetik/index.html"
    },
    {
      "source": "/demos/kosmetikstudio",
      "destination": "/demos/kosmetik/index.html"
    },
    {
      "source": "/demos/lokaler-dienstleister",
      "destination": "/demos/lokaler-dienstleister/index.html"
    },
    {
      "source": "/lokaler-dienstleister-demo",
      "destination": "/demos/lokaler-dienstleister/index.html"
    },
    {
      "source": "/demo-dienstleister",
      "destination": "/demos/lokaler-dienstleister/index.html"
    },
    {
      "source": "/((?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
